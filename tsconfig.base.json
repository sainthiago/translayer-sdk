{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "paths": {
      "@translayer/core": ["packages/core/src/index.ts"],
      "@translayer/providers-openai": ["packages/providers/openai/src/index.ts"],
      "@translayer/providers-deepl": ["packages/providers/deepl/src/index.ts"],
      "@translayer/cache": ["packages/cache/src/index.ts"]
    }
  }
}

